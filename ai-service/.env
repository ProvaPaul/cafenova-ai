APP_NAME=SmartCafe AI Service
APP_VERSION=2.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

BACKEND_URL=http://localhost:8080

RECOMMENDATION_LIMIT=5
CONFIDENCE_MIN=0.30
ANALYTICS_ENABLED=true

# MySQL — must match XAMPP settings
DB_HOST=localhost
DB_PORT=3307
DB_NAME=smart_cafe_db
DB_USER=root
DB_PASSWORD=

# Apriori training parameters
TRAIN_MIN_SUPPORT=0.02
TRAIN_MIN_CONFIDENCE=0.30
TRAIN_MAX_LEN=3

# Scheduled auto-retrain: hour of day (24h) — 0 to disable
AUTO_RETRAIN_HOUR=3
